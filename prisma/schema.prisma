generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Interaction {
  id              String   @id @default(cuid())
  paperId         String
  paperTitle      String
  paperTag        String?
  question        String
  thesisGuess     String
  methodGuess     String
  realThesis      String
  realMethod      String
  thesisFeedback  String?
  methodFeedback  String?
  overallFeedback String?
  createdAt       DateTime @default(now())
}
